#!/bin/bash
# Gradle wrapper script for React Native Android build

GRADLE_VERSION="8.11.1"
GRADLE_USER_HOME="${HOME}/.gradle"
GRADLE_DIST_DIR="${GRADLE_USER_HOME}/wrapper/dists/gradle-${GRADLE_VERSION}-all"
GRADLE_HOME="${GRADLE_DIST_DIR}"

# Create wrapper directory if needed
mkdir -p "$(dirname "$GRADLE_DIST_DIR")"

if [ ! -d "$GRADLE_HOME" ] || [ ! -f "$GRADLE_HOME/gradle-${GRADLE_VERSION}/bin/gradle" ]; then
  echo "Downloading Gradle $GRADLE_VERSION..."
  mkdir -p /tmp/gradle-download
  curl -L https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-all.zip -o /tmp/gradle-download/gradle.zip
  unzip -q /tmp/gradle-download/gradle.zip -d "$GRADLE_DIST_DIR"
fi

# Find the gradle binary
GRADLE_BIN="$GRADLE_HOME/gradle-${GRADLE_VERSION}/bin/gradle"
if [ ! -f "$GRADLE_BIN" ]; then
  # Try alternative path if structured differently
  GRADLE_BIN=$(find "$GRADLE_HOME" -name "gradle" -type f 2>/dev/null | head -1)
fi

if [ -z "$GRADLE_BIN" ] || [ ! -f "$GRADLE_BIN" ]; then
  echo "Error: Could not find Gradle binary"
  exit 1
fi

exec "$GRADLE_BIN" "$@"
